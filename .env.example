# Extra IPs to include in the server TLS certificate's Subject Alternative Names.
# Add the backend host's real IP(s) here so remote clients (e.g. the management
# app running on a different machine) can connect without a certificate error.
# Comma-separated IPv4 or IPv6 addresses. 127.0.0.1 is always included.
#
# After changing these, delete certs/server.crt and certs/server.key so the
# cert is regenerated on next startup.
SERVER_IPS=192.168.1.50

# Extra DNS hostnames to include in the server cert SANs.
# localhost is always included.
SERVER_HOSTS=rmm.example.com,rmm.lan
